# ─────────────────────────────────────────────────────────────────────────────
# PORTFÖY PLATFORM — Ortam Değişkenleri
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun
# ─────────────────────────────────────────────────────────────────────────────

# ── IQVIA API (Gelecek) ──────────────────────────────────────────────────────
# Bu değişkenler tanımlandığında Excel adapter yerine IQVIA API kullanılır
NEXT_PUBLIC_IQVIA_API_URL=
IQVIA_API_KEY=

# ── Midas (Gelecek) ──────────────────────────────────────────────────────────
# Robot/API ile otomatik veri çekme için
NEXT_PUBLIC_MIDAS_URL=
MIDAS_USERNAME=
MIDAS_PASSWORD=

# ── TİTCK (Gelecek) ──────────────────────────────────────────────────────────
TITCK_API_KEY=

# ── Uygulama ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Portföy Seçim Platformu"
ALLOWED_ORIGIN=http://localhost:3000
